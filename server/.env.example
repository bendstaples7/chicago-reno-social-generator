# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cross_poster
DB_USER=postgres
DB_PASSWORD=

# Server
PORT=3001

# OpenAI (content generation + image generation)
AI_TEXT_API_KEY=
AI_TEXT_API_URL=https://api.openai.com/v1/chat/completions

# Instagram / Facebook Graph API
FB_APP_ID=
FB_APP_SECRET=
FB_PAGE_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=

# ── Jobber API ──
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_ACCESS_TOKEN=
JOBBER_REFRESH_TOKEN=

# Jobber Webhook URL (configure in Jobber Developer Center):
# https://your-domain.com/api/webhooks/jobber
# Topics to subscribe: REQUEST_CREATE, REQUEST_UPDATE

# S3-compatible Object Storage (optional)
S3_REGION=us-east-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_MEDIA_BUCKET=cross-poster-media
