# Required environment variables for local development
# Copy this file to .dev.vars and fill in the values

AI_TEXT_API_KEY=
FB_PAGE_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
CHANNEL_ENCRYPTION_KEY=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_ACCESS_TOKEN=
JOBBER_REFRESH_TOKEN=
JOBBER_WEB_EMAIL=
JOBBER_WEB_PASSWORD=

# Frontend URL for OAuth callback redirects (defaults to worker origin if unset)
# In production, set to the Cloudflare Pages URL (e.g., https://cotiza-e4h.pages.dev)
FRONTEND_URL=

# Cloudflare credentials for Browser Rendering REST API (automated cookie refresh)
# Get your account ID from the Cloudflare dashboard URL
# Create an API token with Browser Rendering - Edit permissions
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Enable local-to-remote D1 sync (rules, cookies). Only set in .dev.vars, never in production.
ENABLE_LOCAL_SYNC=true
